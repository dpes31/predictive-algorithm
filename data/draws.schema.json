{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dpes31/predictive-algorithm/data/draws.schema.json",
  "title": "Korean Lotto 6/45 draw archive",
  "type": "object",
  "required": ["data_version", "generated_at", "records"],
  "properties": {
    "data_version": {
      "type": "string",
      "pattern": "^draws-\\d{4}\\.\\d{2}\\.\\d{2}-r\\d+$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "role"],
        "properties": {
          "name": {"type": "string"},
          "url": {"type": "string"},
          "role": {"type": "string"},
          "retrieved_at": {"type": ["string", "null"]},
          "notes": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/draw"}
    }
  },
  "$defs": {
    "draw": {
      "type": "object",
      "required": [
        "draw_no",
        "draw_date",
        "numbers",
        "bonus_number",
        "source",
        "source_reference",
        "verification_status",
        "verified_at",
        "checksum",
        "created_at",
        "updated_at",
        "locked"
      ],
      "properties": {
        "draw_no": {"type": "integer", "minimum": 1},
        "draw_date": {"type": "string", "format": "date"},
        "numbers": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "uniqueItems": true,
          "items": {"type": "integer", "minimum": 1, "maximum": 45}
        },
        "bonus_number": {"type": "integer", "minimum": 1, "maximum": 45},
        "source": {"type": "string"},
        "source_reference": {"type": "string"},
        "verification_status": {
          "type": "string",
          "enum": ["pending_manual", "auto_checked", "verified", "locked"]
        },
        "verified_at": {"type": ["string", "null"], "format": "date-time"},
        "checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "created_at": {"type": "string", "format": "date-time"},
        "updated_at": {"type": "string", "format": "date-time"},
        "locked": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
